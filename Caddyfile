# Local/dev: plain HTTP on :80. On the VPS this is overridden (see the
# Caddyfile.prod pulled in via docker-compose.override.yml) to use a real
# domain so Caddy can auto-provision HTTPS via Let's Encrypt.
:80 {
	handle /api/* {
		reverse_proxy api:8000
	}

	handle {
		root * /srv
		file_server
		try_files {path} /index.html
	}
}
